@model WMSPro.Models.VatTu
@{
    ViewData["Title"] = "Chỉnh sửa vật tư";
    ViewData["SubTitle"] = Model.TenVatTu;
}
<div class="card" style="max-width:900px">
    <div class="card-header"><div class="card-title">✏️ Chỉnh sửa — @Model.MaVatTu</div></div>
    <form asp-action="Sua" method="post">
        <input type="hidden" asp-for="MaVatTu" />
        <div class="form-grid">
            <div class="form-group">
                <label class="form-label">Mã vật tư</label>
                <input class="form-input" value="@Model.MaVatTu" readonly />
            </div>
            <div class="form-group">
                <label class="form-label">Tên vật tư *</label>
                <input class="form-input" asp-for="TenVatTu" />
            </div>
            <div class="form-group">
                <label class="form-label">Loại vật tư</label>
                <select class="form-select" asp-for="LoaiVatTu">
                    <option>Điện tử</option><option>Phụ kiện</option>
                    <option>Linh kiện</option><option>Thiết bị</option><option>Khác</option>
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">Đơn vị tính</label>
                <select class="form-select" asp-for="DonViTinh">
                    <option>cái</option><option>chiếc</option><option>bộ</option>
                    <option>hộp</option><option>kg</option><option>m</option>
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">Số lượng tồn</label>
                <input class="form-input" asp-for="SoLuongTon" type="number" min="0" />
            </div>
            <div class="form-group">
                <label class="form-label">Mức tồn tối thiểu</label>
                <input class="form-input" asp-for="MucTonToiThieu" type="number" min="0" />
            </div>
            <div class="form-group">
                <label class="form-label">Nhà cung cấp</label>
                <select class="form-select" asp-for="MaNhaCungCap">
                    @foreach (var ncc in ViewBag.DanhSachNCC as List<WMSPro.Models.NhaCungCap> ?? new())
                    {
                        <option value="@ncc.MaNhaCungCap" selected="@(ncc.MaNhaCungCap==Model.MaNhaCungCap)">@ncc.TenNhaCungCap</option>
                    }
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">Kho lưu trữ</label>
                <select class="form-select" asp-for="MaKho">
                    @foreach (var kho in ViewBag.DanhSachKho as List<WMSPro.Models.Kho> ?? new())
                    {
                        <option value="@kho.MaKho" selected="@(kho.MaKho==Model.MaKho)">@kho.TenKho</option>
                    }
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">Vị trí</label>
                <select class="form-select" asp-for="MaViTri">
                    @foreach (var vt in ViewBag.DanhSachViTri as List<WMSPro.Models.ViTri> ?? new())
                    {
                        <option value="@vt.MaViTri" selected="@(vt.MaViTri==Model.MaViTri)">@vt.MaViTri (@vt.TinhTrang)</option>
                    }
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">Mã lô</label>
                <input class="form-input" asp-for="MaLo" />
            </div>
            <div class="form-group">
                <label class="form-label">Số seri</label>
                <input class="form-input" asp-for="SoSeri" />
            </div>
        </div>
        <div class="form-actions">
            <a href="/VatTu" class="btn btn-secondary">Hủy bỏ</a>
            <button type="submit" class="btn btn-primary">💾 Lưu thay đổi</button>
        </div>
    </form>
</div>
