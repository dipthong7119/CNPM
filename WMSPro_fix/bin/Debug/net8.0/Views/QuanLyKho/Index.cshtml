@model List<WMSPro.Models.Kho>
@{ ViewData["Title"] = "Quản lý kho"; ViewData["SubTitle"] = "Danh sách kho và sức chứa"; }
<div class="page-actions-bar">
    <div></div>
    <a href="/QuanLyKho/Tao" class="btn btn-primary">+ Thêm kho mới</a>
</div>
<div class="card">
    <div class="card-header"><div class="card-title">🏭 Danh sách kho (@Model.Count)</div></div>
    <table class="table">
        <thead><tr><th>Mã kho</th><th>Tên kho</th><th>Địa điểm</th><th>Người phụ trách</th><th>Ghi chú</th><th>Thao tác</th></tr></thead>
        <tbody>
        @foreach (var kho in Model)
        {
            <tr>
                <td><span class="link">@kho.MaKho</span></td>
                <td style="font-weight:600">@kho.TenKho</td>
                <td>@kho.DiaDiem</td>
                <td>@kho.NguoiPhuTrach</td>
                <td style="color:var(--text2)">@kho.GhiChu</td>
                <td>
                    <div class="action-btns">
                        <a class="btn-icon" href="/QuanLyKho/Sua/@kho.MaKho" title="Sửa">✏️</a>
                        <form method="post" action="/QuanLyKho/Xoa/@kho.MaKho" style="display:inline"
                              onsubmit="return confirm('Xóa kho @kho.TenKho?')">
                            <button type="submit" class="btn-icon btn-icon-danger">🗑️</button>
                        </form>
                    </div>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
