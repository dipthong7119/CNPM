@model List<WMSPro.Models.PhieuXuatKho>
@{
    ViewData["Title"] = "Xuất kho";
    ViewData["SubTitle"] = "Quản lý phiếu xuất và soạn hàng";
    var filter = ViewBag.Filter as string ?? "tat-ca";
}
<div class="page-actions-bar">
    <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap">
        <div class="filter-row">
            <a href="/XuatKho" class="chip @(filter=="tat-ca"?"active":"")">Tất cả</a>
            <a href="/XuatKho?filter=hoan-thanh" class="chip @(filter=="hoan-thanh"?"active":"")">Hoàn thành</a>
            <a href="/XuatKho?filter=dang-soan" class="chip @(filter=="dang-soan"?"active":"")">Đang soạn hàng</a>
            <a href="/XuatKho?filter=cho-duyet" class="chip @(filter=="cho-duyet"?"active":"")">Chờ duyệt</a>
        </div>
        <form method="get" style="display:flex;gap:6px">
            <input type="hidden" name="filter" value="@filter" />
            <div class="search-box" style="width:220px">
                <span>🔍</span><input type="text" name="q" value="@ViewBag.Q" placeholder="Tìm số phiếu, tên hàng..." />
            </div>
            <button type="submit" class="btn btn-secondary btn-sm">Tìm</button>
        </form>
    </div>
    <a href="/XuatKho/Tao" class="btn btn-primary">+ Tạo phiếu xuất</a>
</div>
<div class="card">
    <div class="card-header"><div class="card-title">📤 Danh sách phiếu xuất kho (@Model.Count phiếu)</div></div>
    <table class="table">
        <thead>
            <tr><th>Số phiếu</th><th>Ngày</th><th>Mã hàng</th><th>Tên hàng</th><th>Mã lô</th><th>SL xuất</th><th>Tồn sau xuất</th><th>Đối tác</th><th>Bộ phận nhận</th><th>Lý do</th><th>Trạng thái</th><th>Thao tác</th></tr>
        </thead>
        <tbody>
        @foreach (var p in Model)
        {
            <tr>
                <td><a class="link" href="/XuatKho/Xem/@p.SoPhieu">@p.SoPhieu</a></td>
                <td>@p.Ngay</td><td>@p.MaHang</td><td>@p.TenHang</td>
                <td style="font-family:monospace;font-size:12px">@p.MaLo</td>
                <td class="text-danger">-@p.SlXuat</td>
                <td class="@(p.TonSauXuat<10?"text-danger":p.TonSauXuat<20?"text-yellow":"text-green")">@p.TonSauXuat</td>
                <td>@p.DoiTac</td><td>@p.BoPhanNhan</td><td>@p.LyDoXuat</td>
                <td>
                    @if (p.TrangThai=="Hoàn thành") { <span class="badge badge-green">✓ @p.TrangThai</span> }
                    else if (p.TrangThai=="Đang soạn") { <span class="badge badge-yellow">⏳ @p.TrangThai</span> }
                    else { <span class="badge badge-gray">⏸ @p.TrangThai</span> }
                </td>
                <td>
                    <div class="action-btns">
                        <a class="btn-icon" href="/XuatKho/Xem/@p.SoPhieu" title="Xem">👁️</a>
                        <a class="btn-icon" href="/XuatKho/Sua/@p.SoPhieu" title="Sửa">✏️</a>
                        <form method="post" action="/XuatKho/Xoa/@p.SoPhieu" style="display:inline" onsubmit="return confirm('Xóa phiếu @p.SoPhieu?')">
                            <button type="submit" class="btn-icon btn-icon-danger">🗑️</button>
                        </form>
                    </div>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
