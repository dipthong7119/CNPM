@model WMSPro.Models.PhieuNhapKho
@{ ViewData["Title"] = "Chi tiết phiếu nhập"; ViewData["SubTitle"] = Model.SoPhieu; }
<div class="card" style="max-width:800px">
    <div class="card-header">
        <div class="card-title">📥 Phiếu nhập — @Model.SoPhieu</div>
        <div style="display:flex;gap:8px">
            <a href="/NhapKho/Sua/@Model.SoPhieu" class="btn btn-secondary btn-sm">✏️ Sửa</a>
            <a href="/NhapKho" class="btn btn-secondary btn-sm">← Quay lại</a>
        </div>
    </div>
    <div class="detail-grid">
        <div class="detail-row"><span class="detail-label">Số phiếu</span><span class="detail-val link">@Model.SoPhieu</span></div>
        <div class="detail-row"><span class="detail-label">Ngày chứng từ</span><span class="detail-val">@Model.NgayChungTu</span></div>
        <div class="detail-row"><span class="detail-label">Mã hàng</span><span class="detail-val">@Model.MaHang</span></div>
        <div class="detail-row"><span class="detail-label">Tên hàng</span><span class="detail-val">@Model.TenHang</span></div>
        <div class="detail-row"><span class="detail-label">Mã lô</span><span class="detail-val" style="font-family:monospace">@Model.MaLo</span></div>
        <div class="detail-row"><span class="detail-label">Số lượng</span><span class="detail-val text-green" style="font-size:18px;font-weight:800">+@Model.SlThucTe</span></div>
        <div class="detail-row"><span class="detail-label">Đơn giá</span><span class="detail-val">@Model.DonGia.ToString("N0") VNĐ</span></div>
        <div class="detail-row"><span class="detail-label">Thành tiền</span><span class="detail-val" style="font-weight:700;color:var(--accent);font-size:16px">@Model.ThanhTien.ToString("N0") VNĐ</span></div>
        <div class="detail-row"><span class="detail-label">Nhà cung cấp</span><span class="detail-val">@Model.NhaCungCap</span></div>
        <div class="detail-row"><span class="detail-label">Vị trí gợi ý</span><span class="detail-val"><span class="badge badge-blue">@Model.MaViTriGoiY</span></span></div>
        <div class="detail-row"><span class="detail-label">Ghi chú</span><span class="detail-val">@Model.GhiChu</span></div>
        <div class="detail-row"><span class="detail-label">Trạng thái</span>
            <span class="detail-val">
                @if (Model.TrangThai=="Hoàn thành") { <span class="badge badge-green">✓ @Model.TrangThai</span> }
                else if (Model.TrangThai=="Đang xử lý") { <span class="badge badge-yellow">⏳ @Model.TrangThai</span> }
                else { <span class="badge badge-gray">⏸ @Model.TrangThai</span> }
            </span>
        </div>
    </div>
</div>
