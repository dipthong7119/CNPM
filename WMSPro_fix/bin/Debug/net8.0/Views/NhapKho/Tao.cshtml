@model WMSPro.Models.PhieuNhapKho
@{
    ViewData["Title"] = "Tạo phiếu nhập";
    ViewData["SubTitle"] = "Nhập kho — Kiểm tra và gợi ý vị trí tự động";
    var dsVatTu = ViewBag.DanhSachVatTu as List<WMSPro.Models.VatTu> ?? new();
    var dsNCC = ViewBag.DanhSachNCC as List<WMSPro.Models.NhaCungCap> ?? new();
    var dsViTri = ViewBag.DanhSachViTriTrong as List<WMSPro.Models.ViTri> ?? new();
}
<div class="card" style="max-width:860px">
    <div class="card-header"><div class="card-title">📥 Tạo phiếu nhập kho mới</div></div>
    <form asp-action="Tao" method="post">
        <div class="form-grid">
            <div class="form-group">
                <label class="form-label">Số phiếu</label>
                <input class="form-input" asp-for="SoPhieu" readonly />
            </div>
            <div class="form-group">
                <label class="form-label">Ngày chứng từ</label>
                <input class="form-input" asp-for="NgayChungTu" type="date" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
            </div>
            <div class="form-group">
                <label class="form-label">Mã hàng hóa *</label>
                <select class="form-select" asp-for="MaHang" onchange="capNhatThongTinHang(this)">
                    <option value="">-- Chọn mặt hàng --</option>
                    @foreach (var vt in dsVatTu)
                    {
                        <option value="@vt.MaVatTu" data-ten="@vt.TenVatTu" data-vitri="@vt.MaViTri">@vt.MaVatTu — @vt.TenVatTu (Tồn: @vt.SoLuongTon)</option>
                    }
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">Tên hàng hóa</label>
                <input class="form-input" asp-for="TenHang" id="tenHang" placeholder="Tự động điền khi chọn mã hàng" />
            </div>
            <div class="form-group">
                <label class="form-label">Mã lô hàng</label>
                <input class="form-input" asp-for="MaLo" placeholder="VD: LOT-2024-090" />
            </div>
            <div class="form-group">
                <label class="form-label">Số lượng thực tế *</label>
                <input class="form-input" asp-for="SlThucTe" type="number" min="1" value="0" />
            </div>
            <div class="form-group">
                <label class="form-label">Đơn giá (VNĐ)</label>
                <input class="form-input" asp-for="DonGia" type="number" min="0" value="0" />
            </div>
            <div class="form-group">
                <label class="form-label">Nhà cung cấp</label>
                <select class="form-select" asp-for="MaNhaCungCap">
                    <option value="">-- Chọn nhà cung cấp --</option>
                    @foreach (var ncc in dsNCC)
                    {
                        <option value="@ncc.MaNhaCungCap">@ncc.TenNhaCungCap</option>
                    }
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">Vị trí lưu kho (gợi ý)</label>
                <select class="form-select" name="MaViTriGoiY">
                    @foreach (var vt in dsViTri)
                    {
                        <option value="@vt.MaViTri">@vt.MaViTri (@vt.TinhTrang — @vt.SucChua)</option>
                    }
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">Trạng thái</label>
                <select class="form-select" asp-for="TrangThai">
                    <option>Chờ duyệt</option>
                    <option>Đang xử lý</option>
                    <option>Hoàn thành</option>
                </select>
            </div>
            <div class="form-group form-full">
                <label class="form-label">Ghi chú</label>
                <input class="form-input" asp-for="GhiChu" placeholder="Ghi chú thêm..." />
            </div>
        </div>
        <div class="info-box">
            💡 <strong>Lưu ý:</strong> Khi chọn trạng thái <strong>Hoàn thành</strong>, hệ thống sẽ tự động cập nhật số lượng tồn kho theo công thức:<br>
            <code>Tồn mới = Tồn cũ + Số lượng nhập</code>
        </div>
        <div class="form-actions">
            <a href="/NhapKho" class="btn btn-secondary">Hủy bỏ</a>
            <button type="submit" class="btn btn-primary">💾 Lưu phiếu nhập</button>
        </div>
    </form>
</div>
@section Scripts {
<script>
function capNhatThongTinHang(sel) {
    const opt = sel.options[sel.selectedIndex];
    document.getElementById('tenHang').value = opt.dataset.ten || '';
}
</script>
}
