@model WMSPro.Models.NhaCungCap
@{ ViewData["Title"] = "Chi tiết nhà cung cấp"; ViewData["SubTitle"] = Model.TenNhaCungCap; }
<div class="card" style="max-width:700px">
    <div class="card-header">
        <div class="card-title">🤝 @Model.TenNhaCungCap</div>
        <div style="display:flex;gap:8px">
            <a href="/NhaCungCap/Sua/@Model.MaNhaCungCap" class="btn btn-secondary btn-sm">✏️ Sửa</a>
            <a href="/NhaCungCap" class="btn btn-secondary btn-sm">← Quay lại</a>
        </div>
    </div>
    <div class="detail-grid">
        <div class="detail-row"><span class="detail-label">Mã NCC</span><span class="detail-val link">@Model.MaNhaCungCap</span></div>
        <div class="detail-row"><span class="detail-label">Tên</span><span class="detail-val">@Model.TenNhaCungCap</span></div>
        <div class="detail-row"><span class="detail-label">Địa chỉ</span><span class="detail-val">@Model.DiaChi</span></div>
        <div class="detail-row"><span class="detail-label">Điện thoại</span><span class="detail-val">@Model.SoDienThoai</span></div>
        <div class="detail-row"><span class="detail-label">Email</span><span class="detail-val">@Model.Email</span></div>
    </div>
    @if (ViewBag.VatTuCuaNCC is List<WMSPro.Models.VatTu> dsVt && dsVt.Any())
    {
        <div style="margin-top:20px">
            <div class="card-title" style="margin-bottom:12px">📦 Vật tư đang cung cấp (@dsVt.Count)</div>
            <table class="table">
                <thead><tr><th>Mã</th><th>Tên vật tư</th><th>Tồn kho</th><th>Loại</th></tr></thead>
                <tbody>
                @foreach (var vt in dsVt)
                {
                    <tr><td><a class="link" href="/VatTu/Xem/@vt.MaVatTu">@vt.MaVatTu</a></td><td>@vt.TenVatTu</td><td class="@(vt.TrangThai=="danger"?"text-danger":"text-green")">@vt.SoLuongTon</td><td>@vt.LoaiVatTu</td></tr>
                }
                </tbody>
            </table>
        </div>
    }
</div>
