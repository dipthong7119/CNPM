@model WMSPro.Models.PhieuXuatKho
@{
    ViewData["Title"] = "Tạo phiếu xuất";
    ViewData["SubTitle"] = "Xuất kho — Kiểm tra tồn kho tự động";
    var dsVatTu = ViewBag.DanhSachVatTu as List<WMSPro.Models.VatTu> ?? new();
}
<div class="card" style="max-width:860px">
    <div class="card-header"><div class="card-title">📤 Tạo phiếu xuất kho mới</div></div>
    <form asp-action="Tao" method="post">
        <div class="form-grid">
            <div class="form-group"><label class="form-label">Số phiếu</label><input class="form-input" asp-for="SoPhieu" readonly /></div>
            <div class="form-group"><label class="form-label">Ngày chứng từ</label><input class="form-input" asp-for="Ngay" type="date" value="@DateTime.Now.ToString("yyyy-MM-dd")" /></div>
            <div class="form-group">
                <label class="form-label">Mã hàng hóa *</label>
                <select class="form-select" asp-for="MaHang" onchange="capNhatTonKho(this)">
                    <option value="">-- Chọn mặt hàng --</option>
                    @foreach (var vt in dsVatTu)
                    {
                        <option value="@vt.MaVatTu" data-ten="@vt.TenVatTu" data-ton="@vt.SoLuongTon" data-dvt="@vt.DonViTinh">
                            @vt.MaVatTu — @vt.TenVatTu (Tồn: @vt.SoLuongTon @vt.DonViTinh)
                        </option>
                    }
                </select>
            </div>
            <div class="form-group"><label class="form-label">Tên hàng</label><input class="form-input" asp-for="TenHang" id="tenHang" placeholder="Tự động điền" /></div>
            <div class="form-group">
                <label class="form-label">Tồn kho hiện tại</label>
                <input class="form-input" id="tonHienTai" value="—" readonly style="color:var(--accent);font-weight:700" />
            </div>
            <div class="form-group"><label class="form-label">Số lượng xuất *</label><input class="form-input" asp-for="SlXuat" type="number" min="1" value="0" /></div>
            <div class="form-group"><label class="form-label">Đối tác nhận hàng</label><input class="form-input" asp-for="DoiTac" placeholder="Tên khách hàng / đại lý" /></div>
            <div class="form-group"><label class="form-label">Bộ phận nhận</label><input class="form-input" asp-for="BoPhanNhan" placeholder="VD: Bộ phận Kinh doanh" /></div>
            <div class="form-group"><label class="form-label">Lý do xuất</label><input class="form-input" asp-for="LyDoXuat" placeholder="VD: Bán hàng, Sản xuất..." /></div>
            <div class="form-group">
                <label class="form-label">Lộ trình soạn hàng</label>
                <select class="form-select">
                    <option>Tối ưu tự động</option><option>Thủ công</option>
                </select>
            </div>
            <div class="form-group"><label class="form-label">Trạng thái</label>
                <select class="form-select" asp-for="TrangThai">
                    <option>Chờ duyệt</option><option>Đang soạn</option><option>Hoàn thành</option>
                </select>
            </div>
            <div class="form-group form-full"><label class="form-label">Ghi chú</label><input class="form-input" asp-for="GhiChu" placeholder="Ghi chú..." /></div>
        </div>
        <div class="info-box">
            ⚠️ <strong>Kiểm tra tồn kho:</strong> Hệ thống sẽ tự động kiểm tra <code>Tồn kho >= Số lượng xuất</code> trước khi xác nhận.<br>
            Nếu không đủ tồn kho, hệ thống sẽ thông báo lỗi và không cho xuất.<br>
            Khi trạng thái <strong>Hoàn thành</strong>: <code>Tồn mới = Tồn cũ - Số lượng xuất</code>
        </div>
        <div class="form-actions">
            <a href="/XuatKho" class="btn btn-secondary">Hủy bỏ</a>
            <button type="submit" class="btn btn-primary">💾 Lưu phiếu xuất</button>
        </div>
    </form>
</div>
@section Scripts {
<script>
function capNhatTonKho(sel) {
    const opt = sel.options[sel.selectedIndex];
    document.getElementById('tenHang').value = opt.dataset.ten || '';
    const ton = opt.dataset.ton || '—';
    const dvt = opt.dataset.dvt || '';
    document.getElementById('tonHienTai').value = ton ? `${ton} ${dvt}` : '—';
    document.getElementById('tonHienTai').style.color = parseInt(ton) < 20 ? 'var(--danger)' : 'var(--accent)';
}
</script>
}
