@model WMSPro.Models.NhaCungCap
@{ ViewData["Title"] = "Chỉnh sửa nhà cung cấp"; ViewData["SubTitle"] = Model.TenNhaCungCap; }
<div class="card" style="max-width:700px">
    <div class="card-header"><div class="card-title">✏️ Chỉnh sửa — @Model.MaNhaCungCap</div></div>
    <form asp-action="Sua" method="post">
        <input type="hidden" asp-for="MaNhaCungCap" />
        <div class="form-grid">
            <div class="form-group"><label class="form-label">Mã NCC</label><input class="form-input" value="@Model.MaNhaCungCap" readonly /></div>
            <div class="form-group"><label class="form-label">Tên nhà cung cấp *</label><input class="form-input" asp-for="TenNhaCungCap" /></div>
            <div class="form-group form-full"><label class="form-label">Địa chỉ</label><input class="form-input" asp-for="DiaChi" /></div>
            <div class="form-group"><label class="form-label">Số điện thoại</label><input class="form-input" asp-for="SoDienThoai" /></div>
            <div class="form-group"><label class="form-label">Email</label><input class="form-input" asp-for="Email" type="email" /></div>
        </div>
        <div class="form-actions">
            <a href="/NhaCungCap" class="btn btn-secondary">Hủy bỏ</a>
            <button type="submit" class="btn btn-primary">💾 Lưu thay đổi</button>
        </div>
    </form>
</div>
