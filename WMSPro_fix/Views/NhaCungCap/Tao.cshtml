@model WMSPro.Models.NhaCungCap
@{ ViewData["Title"] = "Thêm nhà cung cấp"; ViewData["SubTitle"] = "Quản lý nhà cung cấp"; }
<div class="card" style="max-width:700px">
    <div class="card-header"><div class="card-title">🤝 Thêm nhà cung cấp mới</div></div>
    <form asp-action="Tao" method="post">
        <div class="form-grid">
            <div class="form-group"><label class="form-label">Mã NCC</label><input class="form-input" asp-for="MaNhaCungCap" readonly /></div>
            <div class="form-group"><label class="form-label">Tên nhà cung cấp *</label><input class="form-input" asp-for="TenNhaCungCap" placeholder="Tên công ty" /></div>
            <div class="form-group form-full"><label class="form-label">Địa chỉ</label><input class="form-input" asp-for="DiaChi" placeholder="Địa chỉ đầy đủ" /></div>
            <div class="form-group"><label class="form-label">Số điện thoại</label><input class="form-input" asp-for="SoDienThoai" placeholder="VD: 024-1234-5678" /></div>
            <div class="form-group"><label class="form-label">Email</label><input class="form-input" asp-for="Email" type="email" placeholder="email@company.vn" /></div>
        </div>
        <div class="form-actions">
            <a href="/NhaCungCap" class="btn btn-secondary">Hủy bỏ</a>
            <button type="submit" class="btn btn-primary">💾 Lưu</button>
        </div>
    </form>
</div>
