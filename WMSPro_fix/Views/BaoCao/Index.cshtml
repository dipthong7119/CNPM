@model List<WMSPro.Models.BaoCaoItem>
@{
    ViewData["Title"] = "Báo cáo";
    ViewData["SubTitle"] = "Báo cáo nhập xuất tồn và lịch sử giao dịch";
    int tongNhap = Model.Sum(x => x.TongNhap);
    int tongXuat = Model.Sum(x => x.TongXuat);
    int tongTon  = Model.Sum(x => x.TonCuoiKy);
}

<div class="tab-bar">
    <div class="tab active" onclick="switchTab(this,'tab-nxt')">Nhập - Xuất - Tồn</div>
    <div class="tab" onclick="switchTab(this,'tab-ls')">Lịch sử giao dịch</div>
    <div class="tab" onclick="switchTab(this,'tab-lo')">Quản lý Lô hàng</div>
</div>

<div id="tab-nxt" class="tab-panel active">
    <div class="report-toolbar">
        <select class="form-select" style="width:160px">
            <option>Tháng 4/2024</option><option>Tháng 3/2024</option><option>Tháng 2/2024</option>
        </select>
        <select class="form-select" style="width:180px">
            <option>Tất cả mặt hàng</option>
            @foreach (var item in Model) { <option>@item.TenHang</option> }
        </select>
        <button class="btn btn-primary btn-sm" onclick="showToast('Đang xuất Excel...','info')">📊 Xuất Excel</button>
    </div>
    <div class="stat-grid" style="grid-template-columns:repeat(3,1fr);margin-bottom:16px">
        <div class="stat-card green"><div class="stat-label">Tổng nhập tháng này</div><div class="stat-val green">+@tongNhap.ToString("N0")</div></div>
        <div class="stat-card red"><div class="stat-label">Tổng xuất tháng này</div><div class="stat-val red">-@tongXuat.ToString("N0")</div></div>
        <div class="stat-card yellow"><div class="stat-label">Tồn cuối kỳ</div><div class="stat-val yellow">@tongTon.ToString("N0")</div></div>
    </div>
    <div class="card">
        <table class="table">
            <thead><tr><th>Mã hàng</th><th>Tên hàng</th><th>Tồn đầu kỳ</th><th>Tổng nhập</th><th>Tổng xuất</th><th>Tồn cuối kỳ</th><th>Đơn vị</th></tr></thead>
            <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.MaHang</td><td>@item.TenHang</td><td>@item.TonDauKy</td>
                    <td class="text-green">+@item.TongNhap</td>
                    <td class="text-danger">-@item.TongXuat</td>
                    <td class="@(item.TonCuoiKy<10?"text-danger":item.TonCuoiKy<20?"text-yellow":"")">@item.TonCuoiKy</td>
                    <td>@item.DonVi</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

<div id="tab-ls" class="tab-panel">
    <div class="card" style="margin-top:16px">
        <div class="card-header"><div class="card-title">📜 Lịch sử giao dịch</div></div>
        <table class="table">
            <thead><tr><th>Thời gian</th><th>Loại</th><th>Số phiếu</th><th>Mặt hàng</th><th>SL</th><th>Người thực hiện</th></tr></thead>
            <tbody>
                <tr><td>02/04/2024 09:15</td><td><span class="badge badge-blue">Nhập</span></td><td><a class="link" href="/NhapKho/Xem/PN-2024-889">PN-2024-889</a></td><td>Điện thoại A12</td><td class="text-green">+50</td><td>Quản Lý Kho</td></tr>
                <tr><td>02/04/2024 08:30</td><td><span class="badge badge-orange">Xuất</span></td><td><a class="link" href="/XuatKho/Xem/PX-2024-845">PX-2024-845</a></td><td>Laptop Core i5</td><td class="text-danger">-12</td><td>Quản Lý Kho</td></tr>
                <tr><td>01/04/2024 14:00</td><td><span class="badge badge-blue">Nhập</span></td><td><a class="link" href="/NhapKho/Xem/PN-2024-888">PN-2024-888</a></td><td>Tai nghe Bluetooth</td><td class="text-green">+100</td><td>Quản Lý Kho</td></tr>
                <tr><td>01/04/2024 10:20</td><td><span class="badge badge-orange">Xuất</span></td><td><a class="link" href="/XuatKho/Xem/PX-2024-844">PX-2024-844</a></td><td>Chuột không dây A200</td><td class="text-danger">-30</td><td>Quản Lý Kho</td></tr>
                <tr><td>30/03/2024 16:00</td><td><span class="badge badge-blue">Nhập</span></td><td><a class="link" href="/NhapKho/Xem/PN-2024-887">PN-2024-887</a></td><td>Bàn phím cơ K300</td><td class="text-green">+60</td><td>Quản Lý Kho</td></tr>
            </tbody>
        </table>
    </div>
</div>

<div id="tab-lo" class="tab-panel">
    <div class="card" style="margin-top:16px">
        <div class="card-header"><div class="card-title">📦 Quản lý Lô hàng</div></div>
        <table class="table">
            <thead><tr><th>Mã lô</th><th>Mặt hàng</th><th>Ngày nhập</th><th>Thời gian lưu</th><th>SL còn lại</th><th>Trạng thái</th></tr></thead>
            <tbody>
                <tr><td style="font-family:monospace">LOT-2024-045</td><td>Điện thoại A12</td><td>02/04/2024</td><td>1 ngày</td><td>245</td><td><span class="badge badge-green">Bình thường</span></td></tr>
                <tr><td style="font-family:monospace">LOT-2024-044</td><td>Tai nghe Bluetooth</td><td>01/04/2024</td><td>2 ngày</td><td>100</td><td><span class="badge badge-green">Bình thường</span></td></tr>
                <tr><td style="font-family:monospace">SP-LOT-0021</td><td>Tai nghe cũ</td><td>05/01/2024</td><td>87 ngày</td><td>45</td><td><span class="badge badge-red">⚠️ Tồn lâu</span></td></tr>
                <tr><td style="font-family:monospace">SN-K300-001</td><td>Bàn phím cơ K300</td><td>30/03/2024</td><td>3 ngày</td><td>15</td><td><span class="badge badge-yellow">⚡ Sắp hết</span></td></tr>
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<script>
function switchTab(el, panelId) {
    document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
    document.querySelectorAll('.tab-panel').forEach(p=>p.classList.remove('active'));
    el.classList.add('active');
    document.getElementById(panelId).classList.add('active');
}
</script>
}
