@model WMSPro.Models.LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Đăng nhập";
}
<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Đăng nhập - WMS Pro</title>
<link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #0d1117;
  --bg2: #161b22;
  --border: #30363d;
  --danger: #ef4444;
  --text2: #8b949e;
}
* { margin:0; padding:0; box-sizing:border-box; }
html, body { width:100%; height:100%; margin:0; padding:0; }
body { 
  font-family: 'Be Vietnam Pro', sans-serif;
  background: var(--bg);
  color: #e6edf3;
}
.login-page { 
  width:100%;
  height:100%;
  display:flex;
  justify-content:center;
  align-items:center;
  background:var(--bg);
}
.login-box {
  width:400px;
  background:var(--bg2);
  border:1px solid var(--border);
  border-radius:16px;
  padding:40px;
  box-shadow:0 20px 60px rgba(0,0,0,.4);
}
.login-logo { text-align:center; margin-bottom:32px; }
.login-logo-icon { font-size:48px; margin-bottom:8px; }
.login-logo-title { font-size:22px; font-weight:800; }
.login-logo-sub { font-size:13px; color:var(--text2); margin-top:4px; }
.login-title { font-size:16px; font-weight:700; margin-bottom:20px; }
.form-group { margin-bottom:14px; }
.form-label { font-size:13px; font-weight:600; display:block; margin-bottom:6px; }
.form-input {
  width:100%;
  padding:10px 12px;
  border:1px solid var(--border);
  border-radius:8px;
  background:#0d1117;
  color:#e6edf3;
  font-size:14px;
}
.form-input:focus {
  outline:none;
  border-color:#00d4aa;
  box-shadow:0 0 0 2px rgba(0,212,170,.1);
}
.btn {
  display:flex;
  align-items:center;
  justify-content:center;
  gap:8px;
  padding:10px 16px;
  border:none;
  border-radius:8px;
  font-weight:600;
  cursor:pointer;
  transition:all .2s;
}
.btn-primary {
  background:#00d4aa;
  color:#000;
  width:100%;
}
.btn-primary:hover { background:#00c994; }
.login-error {
  background:rgba(239,68,68,.12);
  border:1px solid rgba(239,68,68,.3);
  color:var(--danger);
  padding:10px 14px;
  border-radius:8px;
  font-size:13px;
  margin-bottom:16px;
}
.login-hint { font-size:11px; color:var(--text2); margin-top:20px; text-align:center; line-height:1.6; }
</style>
</head>
<body>
<div class="login-page">
    <div class="login-box">
        <div class="login-logo">
            <div class="login-logo-icon">📦</div>
            <div class="login-logo-title">WMS Pro</div>
            <div class="login-logo-sub">Hệ thống Quản lý Kho</div>
        </div>
        <div class="login-title">Đăng nhập hệ thống</div>
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="login-error">⚠️ @Model.ErrorMessage</div>
        }
        <form asp-action="Login" method="post">
            <div class="form-group" style="margin-bottom:14px">
                <label class="form-label">Tên đăng nhập</label>
                <input class="form-input" asp-for="TenDangNhap" placeholder="Nhập tên đăng nhập" autofocus />
            </div>
            <div class="form-group" style="margin-bottom:20px">
                <label class="form-label">Mật khẩu</label>
                <input class="form-input" asp-for="MatKhau" type="password" placeholder="Nhập mật khẩu" />
            </div>
            <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;padding:10px">
                🔐 Đăng nhập
            </button>
        </form>
        <div class="login-hint">
            Tài khoản mặc định:<br>
            Admin: <strong>admin</strong> / <strong>admin123</strong><br>
            Thủ kho: <strong>thukho</strong> / <strong>thukho123</strong>
        </div>
    </div>
</div>
</body>
</html>
