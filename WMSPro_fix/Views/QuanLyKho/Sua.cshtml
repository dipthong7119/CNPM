@model WMSPro.Models.Kho
@{ ViewData["Title"] = "Chỉnh sửa kho"; ViewData["SubTitle"] = Model.TenKho; }
<div class="card" style="max-width:700px">
    <div class="card-header"><div class="card-title">✏️ Chỉnh sửa — @Model.MaKho</div></div>
    <form asp-action="Sua" method="post">
        <input type="hidden" asp-for="MaKho" />
        <div class="form-grid">
            <div class="form-group"><label class="form-label">Mã kho</label><input class="form-input" value="@Model.MaKho" readonly /></div>
            <div class="form-group"><label class="form-label">Tên kho *</label><input class="form-input" asp-for="TenKho" /></div>
            <div class="form-group"><label class="form-label">Địa điểm</label><input class="form-input" asp-for="DiaDiem" /></div>
            <div class="form-group"><label class="form-label">Người phụ trách</label><input class="form-input" asp-for="NguoiPhuTrach" /></div>
            <div class="form-group form-full"><label class="form-label">Ghi chú</label><input class="form-input" asp-for="GhiChu" /></div>
        </div>
        <div class="form-actions">
            <a href="/QuanLyKho" class="btn btn-secondary">Hủy bỏ</a>
            <button type="submit" class="btn btn-primary">💾 Lưu thay đổi</button>
        </div>
    </form>
</div>
