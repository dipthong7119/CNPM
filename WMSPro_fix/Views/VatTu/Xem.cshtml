@model WMSPro.Models.VatTu
@{
    ViewData["Title"] = "Chi tiết vật tư";
    ViewData["SubTitle"] = Model.TenVatTu;
}
<div class="card" style="max-width:800px">
    <div class="card-header">
        <div class="card-title">🔧 Chi tiết vật tư — @Model.MaVatTu</div>
        <div style="display:flex;gap:8px">
            <a href="/VatTu/Sua/@Model.MaVatTu" class="btn btn-secondary btn-sm">✏️ Chỉnh sửa</a>
            <a href="/VatTu" class="btn btn-secondary btn-sm">← Quay lại</a>
        </div>
    </div>
    <div class="detail-grid">
        <div class="detail-row"><span class="detail-label">Mã vật tư</span><span class="detail-val link">@Model.MaVatTu</span></div>
        <div class="detail-row"><span class="detail-label">Tên vật tư</span><span class="detail-val">@Model.TenVatTu</span></div>
        <div class="detail-row"><span class="detail-label">Loại</span><span class="detail-val">@Model.LoaiVatTu</span></div>
        <div class="detail-row"><span class="detail-label">Đơn vị tính</span><span class="detail-val">@Model.DonViTinh</span></div>
        <div class="detail-row">
            <span class="detail-label">Số lượng tồn</span>
            <span class="detail-val @(Model.TrangThai=="danger"?"text-danger":Model.TrangThai=="warning"?"text-yellow":"text-green")" style="font-size:20px;font-weight:800">
                @Model.SoLuongTon @Model.DonViTinh
            </span>
        </div>
        <div class="detail-row"><span class="detail-label">Mức tồn tối thiểu</span><span class="detail-val">@Model.MucTonToiThieu @Model.DonViTinh</span></div>
        <div class="detail-row"><span class="detail-label">Nhà cung cấp</span><span class="detail-val">@Model.TenNhaCungCap</span></div>
        <div class="detail-row"><span class="detail-label">Kho lưu trữ</span><span class="detail-val">@Model.MaKho</span></div>
        <div class="detail-row"><span class="detail-label">Vị trí</span><span class="detail-val">@Model.MaViTri</span></div>
        <div class="detail-row"><span class="detail-label">Mã lô</span><span class="detail-val" style="font-family:monospace">@Model.MaLo</span></div>
        <div class="detail-row"><span class="detail-label">Số seri</span><span class="detail-val" style="font-family:monospace">@Model.SoSeri</span></div>
        <div class="detail-row">
            <span class="detail-label">Trạng thái</span>
            <span class="detail-val">
                @if (Model.TrangThai == "danger") { <span class="badge badge-red">⚠️ Dưới mức tối thiểu</span> }
                else if (Model.TrangThai == "warning") { <span class="badge badge-yellow">⚡ Sắp hết</span> }
                else { <span class="badge badge-green">✓ Bình thường</span> }
            </span>
        </div>
    </div>
</div>
