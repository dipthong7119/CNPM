@model WMSPro.Models.PhieuNhapKho
@{ ViewData["Title"] = "Chỉnh sửa phiếu nhập"; ViewData["SubTitle"] = Model.SoPhieu; }
<div class="card" style="max-width:860px">
    <div class="card-header"><div class="card-title">✏️ Chỉnh sửa — @Model.SoPhieu</div></div>
    <form asp-action="Sua" method="post">
        <input type="hidden" asp-for="SoPhieu" />
        <input type="hidden" asp-for="MaViTriGoiY" />
        <div class="form-grid">
            <div class="form-group"><label class="form-label">Số phiếu</label><input class="form-input" value="@Model.SoPhieu" readonly /></div>
            <div class="form-group"><label class="form-label">Ngày chứng từ</label><input class="form-input" asp-for="NgayChungTu" type="date" /></div>
            <div class="form-group">
                <label class="form-label">Mã hàng</label>
                <select class="form-select" asp-for="MaHang">
                    @foreach (var vt in ViewBag.DanhSachVatTu as List<WMSPro.Models.VatTu> ?? new())
                    { <option value="@vt.MaVatTu" selected="@(vt.MaVatTu==Model.MaHang)">@vt.MaVatTu — @vt.TenVatTu</option> }
                </select>
            </div>
            <div class="form-group"><label class="form-label">Tên hàng</label><input class="form-input" asp-for="TenHang" /></div>
            <div class="form-group"><label class="form-label">Mã lô</label><input class="form-input" asp-for="MaLo" /></div>
            <div class="form-group"><label class="form-label">Số lượng *</label><input class="form-input" asp-for="SlThucTe" type="number" min="1" /></div>
            <div class="form-group"><label class="form-label">Đơn giá</label><input class="form-input" asp-for="DonGia" type="number" min="0" /></div>
            <div class="form-group">
                <label class="form-label">Nhà cung cấp</label>
                <select class="form-select" asp-for="MaNhaCungCap">
                    @foreach (var ncc in ViewBag.DanhSachNCC as List<WMSPro.Models.NhaCungCap> ?? new())
                    { <option value="@ncc.MaNhaCungCap" selected="@(ncc.MaNhaCungCap==Model.MaNhaCungCap)">@ncc.TenNhaCungCap</option> }
                </select>
            </div>
            <div class="form-group"><label class="form-label">Trạng thái</label>
                <select class="form-select" asp-for="TrangThai">
                    <option>Chờ duyệt</option><option>Đang xử lý</option><option>Hoàn thành</option>
                </select>
            </div>
            <div class="form-group form-full"><label class="form-label">Ghi chú</label><input class="form-input" asp-for="GhiChu" /></div>
        </div>
        <div class="form-actions">
            <a href="/NhapKho" class="btn btn-secondary">Hủy bỏ</a>
            <button type="submit" class="btn btn-primary">💾 Lưu thay đổi</button>
        </div>
    </form>
</div>
