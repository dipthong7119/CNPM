@model List<WMSPro.Models.PhieuNhapKho>
@{
    ViewData["Title"] = "Nhập kho";
    ViewData["SubTitle"] = "Quản lý phiếu nhập và tiếp nhận hàng hóa";
    var filter = ViewBag.Filter as string ?? "tat-ca";
}
<div class="page-actions-bar">
    <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap">
        <div class="filter-row">
            <a href="/NhapKho" class="chip @(filter=="tat-ca"?"active":"")">Tất cả</a>
            <a href="/NhapKho?filter=hoan-thanh" class="chip @(filter=="hoan-thanh"?"active":"")">Hoàn thành</a>
            <a href="/NhapKho?filter=dang-xu-ly" class="chip @(filter=="dang-xu-ly"?"active":"")">Đang xử lý</a>
            <a href="/NhapKho?filter=cho-duyet" class="chip @(filter=="cho-duyet"?"active":"")">Chờ duyệt</a>
        </div>
        <form method="get" style="display:flex;gap:6px">
            <input type="hidden" name="filter" value="@filter" />
            <div class="search-box" style="width:220px">
                <span>🔍</span><input type="text" name="q" value="@ViewBag.Q" placeholder="Tìm số phiếu, tên hàng..." />
            </div>
            <button type="submit" class="btn btn-secondary btn-sm">Tìm</button>
        </form>
    </div>
    <a href="/NhapKho/Tao" class="btn btn-primary">+ Tạo phiếu nhập</a>
</div>
<div class="card">
    <div class="card-header"><div class="card-title">📥 Danh sách phiếu nhập kho (@Model.Count phiếu)</div></div>
    <table class="table">
        <thead>
            <tr><th>Số phiếu</th><th>Ngày</th><th>Mã hàng</th><th>Tên hàng</th><th>Mã lô</th><th>SL</th><th>Đơn giá</th><th>Thành tiền</th><th>Nhà cung cấp</th><th>Vị trí gợi ý</th><th>Trạng thái</th><th>Thao tác</th></tr>
        </thead>
        <tbody>
        @foreach (var p in Model)
        {
            <tr>
                <td><a class="link" href="/NhapKho/Xem/@p.SoPhieu">@p.SoPhieu</a></td>
                <td>@p.NgayChungTu</td><td>@p.MaHang</td><td>@p.TenHang</td>
                <td style="font-family:monospace;font-size:12px">@p.MaLo</td>
                <td>@p.SlThucTe</td><td>@p.DonGia.ToString("N0")</td>
                <td style="font-weight:600;color:var(--accent)">@p.ThanhTien.ToString("N0")</td>
                <td>@p.NhaCungCap</td>
                <td><span class="badge badge-blue">@p.MaViTriGoiY</span></td>
                <td>
                    @if (p.TrangThai=="Hoàn thành") { <span class="badge badge-green">✓ @p.TrangThai</span> }
                    else if (p.TrangThai=="Đang xử lý") { <span class="badge badge-yellow">⏳ @p.TrangThai</span> }
                    else { <span class="badge badge-gray">⏸ @p.TrangThai</span> }
                </td>
                <td>
                    <div class="action-btns">
                        <a class="btn-icon" href="/NhapKho/Xem/@p.SoPhieu" title="Xem">👁️</a>
                        <a class="btn-icon" href="/NhapKho/Sua/@p.SoPhieu" title="Sửa">✏️</a>
                        <form method="post" action="/NhapKho/Xoa/@p.SoPhieu" style="display:inline" onsubmit="return confirm('Xóa phiếu @p.SoPhieu?')">
                            <button type="submit" class="btn-icon btn-icon-danger">🗑️</button>
                        </form>
                    </div>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
