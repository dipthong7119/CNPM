@model IEnumerable<QuanLyKhoMVC.Models.VatTu>

@{
    ViewData["Title"] = "Danh sách vật tư";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="text-primary"><i class="bi bi-box-seam"></i> Quản Lý Kho Vật Tư</h2>
        <a href="/VatTus/Create" class="btn btn-success shadow-sm">
            <i class="bi bi-plus-circle"></i> + Nhập Vật Tư Mới
        </a>
    </div>

    <div class="card shadow">
        <div class="card-body">
            <table class="table table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Mã Vật Tư</th>
                        <th>Tên Vật Tư</th>
                        <th>Số Lượng</th>
                        <th>Vị Trí</th>
                        <th class="text-center">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null)   
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-bold text-secondary">@item.MaVatTu</td>
                                <td>@item.TenVatTu</td>
                                <td>
                                    <span class="badge @(item.SoLuong < 5 ? "bg-danger" : "bg-info")">
                                        @item.SoLuong
                                    </span>
                                </td>
                                <td>@item.ViTri</td>
                                <td class="text-center">
                                    <a href="/VatTus/Edit/@item.MaVatTu" class="btn btn-sm btn-outline-warning">Sửa</a>
                                    <a href="/VatTus/Delete/@item.MaVatTu" class="btn btn-sm btn-outline-danger">Xuất</a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="mt-3 alert alert-secondary">
        <strong>Thống kê:</strong> Tổng số loại vật tư: @(Model?.Count() ?? 0)
    </div>
</div>