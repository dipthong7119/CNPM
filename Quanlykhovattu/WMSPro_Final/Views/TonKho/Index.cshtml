@model List<WMSPro.Models.VatTu>
@{
    ViewData["Title"] = "Tồn kho";
    ViewData["SubTitle"] = "Theo dõi số lượng theo thời gian thực";
    var filter = ViewBag.Filter as string ?? "tat-ca";
}
<div class="page-actions-bar">
    <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap">
        <div class="filter-row">
            <a href="/TonKho" class="chip @(filter == "tat-ca" ? "active" : "")">🔷 Lưới</a>
            <a href="/TonKho?filter=sap-het" class="chip @(filter == "sap-het" ? "active" : "")">⚠️ Sắp hết</a>
            <a href="/TonKho?filter=tat-ca" class="chip">🔄 Tất cả</a>
        </div>
        <form method="get" style="display:flex;gap:6px">
            <input type="hidden" name="filter" value="@filter" />
            <div class="search-box" style="width:220px">
                <span>🔍</span><input type="text" name="q" value="@ViewBag.Q" placeholder="Tìm tên, mã vật tư..." />
            </div>
            <button type="submit" class="btn btn-secondary btn-sm">Tìm</button>
        </form>
    </div>
    <a href="/BaoCao" class="btn btn-secondary">📊 Xuất báo cáo</a>
</div>

<div class="stock-grid">
    @foreach (var item in Model)
    {
        var max = Math.Max(item.MucTonToiThieu * 5, item.SoLuongTon + 10);
        var pct = (int)Math.Min((double)item.SoLuongTon / max * 100, 100);
        <div class="stock-card @item.TrangThai">
            <div class="stock-card-code">@item.MaVatTu</div>
            <div class="stock-card-name">@item.TenVatTu</div>
            <div class="stock-card-qty @item.TrangThai">
                @item.SoLuongTon <span class="stock-card-unit">@item.DonViTinh</span>
            </div>
            <div class="stock-progress">
                <div class="stock-progress-bar @item.TrangThai" style="width:@pct%"></div>
            </div>
            @if (item.TrangThai == "danger")
            {
                <div class="stock-card-alert danger">⚠️ Dưới mức tối thiểu (@item.MucTonToiThieu)</div>
            }
            else if (item.TrangThai == "warning")
            {

                <div class="stock-card-alert warning">⚡ Sắp đạt mức tối thiểu</div>
            }
            else
            {

                <div class="stock-card-info">📍 @item.MaViTri · Lô: @item.MaLo</div>
            }
            <div style="margin-top:10px;display:flex;gap:6px">
                <a href="/VatTu/Xem/@item.Id" class="btn btn-secondary btn-sm" style="flex:1;justify-content:center">👁️ Xem</a>
                <a href="/NhapKho/Tao" class="btn btn-primary btn-sm" style="flex:1;justify-content:center">+ Nhập</a>
            </div>
        </div>
    }
</div>
